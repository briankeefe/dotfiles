adjust-cell-height = 10%
background-blur-radius = 60
background-opacity = 1.00
bold-is-bright = false
confirm-close-surface = false
cursor-style = bar
font-family = {{ .terminal_font | quote }}
font-size = 12
gtk-single-instance = true
mouse-hide-while-typing = true
quick-terminal-position = center
selection-background = #2d3f76
selection-foreground = #c8d3f5
shell-integration = detect
shell-integration-features = cursor,sudo
term = xterm-256color
title = GhosTTY
unfocused-split-opacity = 0.5
wait-after-command = false
window-height = 32
window-save-state = always
window-theme = dark
window-width = 110

# Stable manual theme. Keep this last so autogenerated palettes don't override it.
config-file = ?~/.config/ghostty/theme.conf

# Disabled for now: autogenerated Wallust colors were producing inconsistent results.
# config-file = ?~/.config/ghostty/wallust.conf
