{
  "$schema": "https://opencode.ai/config.json",
  "model": "{{ .opencode_model }}",
  "autoupdate": "notify",
  "share": "manual",
  "snapshot": true,
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**"
    ]
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    }
  },
  "agent": {
    "foreman": {
      "color": "#FF2D95",
      "reasoningEffort": "high"
    },
    "build": {
      "color": "#4CC9F0",
      "reasoningEffort": "medium"
    },
    "plan": {
      "color": "#FFD700",
      "reasoningEffort": "high"
    },
    "builder-lite": {
      "color": "#00FFFF",
      "reasoningEffort": "medium"
    },
    "search-lite": {
      "color": "#BF00FF",
      "reasoningEffort": "low"
    },
    "review-lite": {
      "color": "#FF6B00",
      "reasoningEffort": "medium"
    },
    "docs-lite": {
      "color": "#39FF14",
      "reasoningEffort": "low"
    }
  },
  "provider": {
    "openai": {
      "options": {
        "apiKey": "{file:~/.secrets/opencode/openai_api_key}"
      }
    }
  }
}
