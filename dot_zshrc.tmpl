# Powerlevel10k instant prompt. Keep near top for startup speed.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

export ZSH="$HOME/.oh-my-zsh"

{{- if eq .chezmoi.os "darwin" }}
ZSH_THEME="powerlevel10k/powerlevel10k"

plugins=(
  git
  alias-finder
  history-substring-search
  command-not-found
)
{{- else }}
ZSH_THEME=""

plugins=(
  git
  archlinux
  zsh-autosuggestions
  zsh-syntax-highlighting
)
{{- end }}

source $ZSH/oh-my-zsh.sh

{{- if eq .chezmoi.os "darwin" }}
# Homebrew zsh plugins
source /opt/homebrew/opt/zsh-autosuggestions/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source /opt/homebrew/opt/zsh-syntax-highlighting/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
[[ -s /opt/homebrew/opt/autojump/share/autojump/autojump.zsh ]] && source /opt/homebrew/opt/autojump/share/autojump/autojump.zsh
{{- else }}
# Powerlevel10k via zinit
[[ -r "$HOME/.local/share/zinit/plugins/romkatv---powerlevel10k/powerlevel10k.zsh-theme" ]] && \
  source "$HOME/.local/share/zinit/plugins/romkatv---powerlevel10k/powerlevel10k.zsh-theme"
{{- end }}

[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

{{- if ne .chezmoi.os "darwin" }}

# Keep directory colors readable.
export LS_COLORS="${LS_COLORS//ow=34;42/ow=01;34}"
export LS_COLORS="${LS_COLORS//tw=30;42/tw=01;34}"
export LS_COLORS="${LS_COLORS//st=37;44/st=01;34}"
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"

# Display fastfetch only for login shells.
if [[ -o login ]]; then
  fastfetch -c "$HOME/.config/fastfetch/config-compact.jsonc"
fi

alias ls='lsd'
alias l='ls -l'
alias la='ls -a'
alias lla='ls -la'
alias lt='ls --tree'
alias dot='chezmoi'
alias dotdiff='chezmoi diff'
alias dotapply='chezmoi apply'

dotedit() {
  chezmoi edit "$@"
}

dotadd() {
  chezmoi add "$@"
}

source <(fzf --zsh)
{{- end }}

HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt appendhistory

export PATH="$HOME/bin:$HOME/.local/bin:$HOME/.bun/bin:$HOME/.opencode/bin:$PATH"

{{- if eq .chezmoi.os "darwin" }}
export PATH="$HOME/.npm-global/bin:$PATH"

# nvm
export NVM_DIR="$HOME/.nvm"
[ -s "$(brew --prefix nvm)/nvm.sh" ] && \. "$(brew --prefix nvm)/nvm.sh"
[ -s "$(brew --prefix nvm)/etc/bash_completion.d/nvm" ] && \. "$(brew --prefix nvm)/etc/bash_completion.d/nvm"

# mysql-client
export PATH="/opt/homebrew/opt/mysql-client/bin:$PATH"

# pyenv
export PYENV_ROOT="$HOME/.pyenv"
export PATH="$PYENV_ROOT/bin:$PATH"
eval "$(pyenv init -)"

# Java
export JAVA_HOME=$(/usr/libexec/java_home -v 17)

# bun
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# AgentNotch - AI coding assistant telemetry
export OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
export OMO_DISABLE_POSTHOG=1
{{- end }}

{{- if .work }}
export GIT_AUTHOR_EMAIL={{ .email | quote }}
export GIT_COMMITTER_EMAIL={{ .email | quote }}
{{- end }}

# Machine-local secrets (never tracked in git). See ~/.secrets/shell/env.zsh.
[ -f "$HOME/.secrets/shell/env.zsh" ] && source "$HOME/.secrets/shell/env.zsh"

opencode() {
  local stamp="${XDG_STATE_HOME:-$HOME/.local/state}/opencode-agents-last-update"
  local repo="${OPENCODE_AGENTS_REPO:-$HOME/.config/opencode-agents}"
  if [[ -d "$repo" ]]; then
    local now=$(date +%s)
    local last=0
    [[ -f "$stamp" ]] && last=$(<"$stamp")
    if (( now - last > 86400 )); then
      (cd "$repo" && git pull --ff-only -q && ./install.sh) 2>/dev/null && echo "$now" > "$stamp"
    fi
  fi
{{- if eq .chezmoi.os "darwin" }}
  OPENCODE_DISABLE_DEFAULT_PLUGINS=true command opencode "$@"
{{- else }}
  command opencode "$@"
{{- end }}
}

{{- if ne .chezmoi.os "darwin" }}

dotfiles_auto_update() {
  local stamp="${XDG_STATE_HOME:-$HOME/.local/state}/dotfiles-last-update"
  local now last=0

  command -v chezmoi >/dev/null 2>&1 || return 0

  now=$(date +%s)
  [[ -f "$stamp" ]] && last=$(<"$stamp")
  (( now - last < 86400 )) && return 0

  mkdir -p "${stamp:h}"

  (
    chezmoi update --apply >/dev/null 2>&1 && printf '%s' "$now" > "$stamp"
  ) &!
}

dotfiles_auto_update
{{- end }}
